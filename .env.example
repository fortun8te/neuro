# Environment Configuration
# Copy this file to .env and update for your environment

# ============================================
# INFRASTRUCTURE MODE
# ============================================
# Options: 'local' (localhost) or 'remote' (Tailscale/VPN)
# Default: 'local' (for local development)
# Override in .env.production: 'remote'
VITE_INFRASTRUCTURE_MODE=local

# ============================================
# OLLAMA (Local LLM Backend)
# ============================================
# LOCAL: User's machine (http://localhost:11434)
# REMOTE: Remote server via Tailscale (http://100.74.135.83:11434)
# Models: qwen3.5:0.8b, qwen3.5:2b, qwen3.5:4b, qwen3.5:9b, qwen3.5:27b, gpt-oss-20b
VITE_OLLAMA_URL=http://localhost:11434

# ============================================
# WAYFARER (Web Scraping & Research Service)
# ============================================
# LOCAL: User's machine (http://localhost:8889)
# REMOTE: Remote server via Tailscale (http://100.74.135.83:8889)
# Requires: Python 3.11+, pvlwebtools
VITE_WAYFARER_URL=http://localhost:8889

# ============================================
# SEARXNG (Meta-Search Engine)
# ============================================
# LOCAL: Docker container (http://localhost:8888)
# REMOTE: Remote server via Tailscale (http://100.74.135.83:8888)
VITE_SEARXNG_URL=http://localhost:8888

# ============================================
# PERFORMANCE TUNING
# ============================================
VITE_SEARXNG_CONCURRENCY=32
VITE_SEARXNG_INSTANCES=8
VITE_WAYFARER_CONCURRENCY=20

