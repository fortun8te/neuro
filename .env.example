# Infrastructure Configuration
# Point to your remote services or leave blank for defaults

# Ollama LLM Service
# Default: http://100.74.135.83:11440 (remote)
# Local: http://localhost:11434
VITE_OLLAMA_URL=

# Wayfarer Web Scraping Service
# Default: http://localhost:8889 (local)
# Remote: http://YOUR_PC_IP:8889
VITE_WAYFARER_URL=

# SearXNG Meta-Search Engine
# Default: http://localhost:8888 (Docker)
# Remote: http://YOUR_PC_IP:8888
VITE_SEARXNG_URL=

# =====================================================================
# SECURITY: Wayfarer CORS & API Key Configuration
# =====================================================================

# CORS: List of allowed origins for Wayfarer requests
# Default: http://localhost:5173,http://localhost:3000
# Production: Set to your actual frontend domain (comma-separated)
# SECURITY: Remove this if relying on network isolation (e.g., VPC/Tailscale)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# API Key: Required for sensitive operations (JavaScript evaluation via /evaluate)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# If not set, API key requirement is disabled (suitable for localhost only)
# Production: Always set this to a strong random value
WAYFARER_API_KEY=

# Feature Flags
# Enable approval gates for expensive operations (ask before make/test/strategy if > token threshold)
VITE_APPROVAL_GATES_ENABLED=false

# Enable skill library & knowledge extraction from cycles
# Automatically extracts patterns (audience, messaging, creative, research) from completed cycles
# Reuses learnings in subsequent campaigns for better performance
VITE_SKILL_LIBRARY_ENABLED=true

# Health Monitoring & Graceful Degradation (Phase 11)
# Enable continuous health checking of all services (Ollama, Wayfarer, SearXNG, Context-1)
VITE_HEALTH_MONITORING_ENABLED=true

# Enable graceful degradation (use fallbacks when services unavailable)
VITE_GRACEFUL_DEGRADATION_ENABLED=true

# Enable process watchdog (auto-restart crashed researchers, track failures)
VITE_PROCESS_WATCHDOG_ENABLED=true

# Phase 1: Advanced Research Orchestration
# Enable dynamic query generation and intelligent routing to researchers
# Generates 5 focused queries covering: market, behavior, competitive, objections, messaging
# Routes queries to parallel researchers for pyramid reduction (100 → 50 → 20 URLs)
# Expected: 60% token reduction vs broad orchestrator search
VITE_QUERY_ROUTING_ENABLED=true

# Query routing strategy: 'standard' or 'adaptive'
# standard: Fixed routing (5 queries × 5 researchers per round)
# adaptive: Adjusts based on coverage feedback after each round
VITE_QUERY_ROUTING_STRATEGY=standard

# Firebase Config (optional, for authentication)
# Replace with your Firebase credentials from https://console.firebase.google.com
VITE_FIREBASE_API_KEY=sk_test_YOUR_FIREBASE_API_KEY_HERE
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Meta API (optional)
# Replace with your Meta/Facebook app credentials
VITE_META_APP_ID=your_app_id
VITE_META_APP_SECRET=sk_test_YOUR_META_APP_SECRET_HERE

# Phase 4: Infrastructure Hardening (Timeouts, Watchdog, Crash Recovery)
# Enable aggressive request-level timeouts (30s per request, 2h per phase)
VITE_AGGRESSIVE_TIMEOUTS_ENABLED=true

# Enable timeout pyramid (graceful degradation when stages exceed budget)
VITE_TIMEOUT_PYRAMID_ENABLED=true

# Enable process watchdog (monitors service health, auto-restarts on failure)
VITE_WATCHDOG_ENABLED=true

# Enable crash recovery (persist checkpoints, resume after crash)
VITE_CRASH_RECOVERY_ENABLED=true

# Checkpoint save interval (milliseconds, default: 30 seconds)
VITE_SESSION_CHECKPOINTING_INTERVAL=30000

# Enable overnight mode (24h+ unattended operation)
VITE_OVERNIGHT_MODE_ENABLED=true

# Watchdog monitoring interval (milliseconds, default: 30 seconds)
VITE_WATCHDOG_INTERVAL=30000

# Health check timeout (milliseconds, default: 5 seconds)
VITE_HEALTH_CHECK_TIMEOUT=5000

# Q3 Benchmark Mode (Phase 5)
# Enable comprehensive performance benchmarking and metric collection
# Tracks: phase metrics, token usage, timing, memory, model performance
# Outputs JSON report to /tmp/q3-benchmark-{timestamp}.json on cycle complete
VITE_Q3_BENCHMARK_MODE=false

# Request-level timeout (milliseconds, kills hanging API calls)
VITE_TIMEOUT_REQUEST=30000

# Phase-level timeout (milliseconds, max budget per stage)
VITE_TIMEOUT_PHASE=7200000

# Process memory limit (bytes, default: 1GB for 32-bit safety)
VITE_MEMORY_LIMIT=1073741824
