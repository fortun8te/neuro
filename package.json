{
  "name": "ad-agent",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "trap 'kill $(jobs -p) 2>/dev/null' EXIT; /opt/homebrew/bin/python3.11 -m uvicorn freepik_server:app --host 0.0.0.0 --port 8890 & node telegram-bot.js & vite",
    "dev:vite": "vite",
    "dev:freepik": "/opt/homebrew/bin/python3.11 -m uvicorn freepik_server:app --host 0.0.0.0 --port 8890",
    "bot": "node telegram-bot.js",
    "bot:bg": "nohup node telegram-bot.js > /tmp/telegram-bot.log 2>&1 &",
    "build": "tsc -b --force && vite build",
    "build:clean": "rm -f node_modules/.tmp/tsconfig.app.tsbuildinfo node_modules/.tmp/tsconfig.node.tsbuildinfo && tsc -b --force && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:agent": "tsx test-agent-complexity.ts",
    "cli": "tsx frontend/cli.ts",
    "cli:dev": "tsx --watch frontend/cli.ts",
    "research": "tsx src/cli-research.ts",
    "research:dev": "tsx --watch src/cli-research.ts",
    "research:leak": "tsx src/cli-research-leak.ts",
    "research:leak:subagents": "tsx src/cli-research-leak-subagents.ts",
    "research:batch": "node scripts/batch-research.js",
    "research:batch:sh": "bash scripts/run-all-research.sh",
    "research:questions": "node scripts/batch-questions.js",
    "research:questions:simple": "node scripts/batch-questions.js --categories A,B --limit 10",
    "research:questions:complex": "node scripts/batch-questions.js --categories H --limit 5",
    "batch": "tsx src/cli-batch.ts",
    "batch:quick": "tsx src/cli-batch.ts -- --limit 10",
    "batch:marketing": "tsx src/cli-batch.ts -- --category marketing",
    "batch:technical": "tsx src/cli-batch.ts -- --category technical",
    "deep-research": "tsx src/cli-deep-research.ts",
    "deep-research:dev": "tsx --watch src/cli-deep-research.ts",
    "test:phase1": "tsx test-phase1-e2e.ts"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "@novnc/novnc": "^1.6.0",
    "@paper-design/shaders-react": "^0.0.72",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/ws": "^8.18.1",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.6.2",
    "class-variance-authority": "^0.7.1",
    "cli-table3": "^0.6.5",
    "docx": "^9.6.1",
    "dompurify": "^3.3.3",
    "dotenv": "^17.3.1",
    "file-saver": "^2.0.5",
    "firebase": "^12.11.0",
    "framer-motion": "^12.35.2",
    "highlight.js": "^11.11.1",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "idb-keyval": "^6.2.2",
    "js-tiktoken": "^1.0.21",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "p-limit": "^7.3.0",
    "pdfjs-dist": "^5.5.207",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "strip-ansi": "^7.2.0",
    "telegraf": "^4.16.3",
    "vis-network": "^10.0.2",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^24.10.15",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/ui": "^4.1.2",
    "autoprefixer": "^10.4.24",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "happy-dom": "^20.8.9",
    "playwright": "^1.58.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.2"
  }
}
